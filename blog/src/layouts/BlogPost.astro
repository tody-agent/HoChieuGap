---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import ArticleCTA from '../components/ArticleCTA.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import SearchOverlay from '../components/SearchOverlay.astro';
import { BRAND, CLUSTERS } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & { slug?: string; relatedSlugs?: string[] };

const { title, description, pubDate, updatedDate, heroImage, cluster, keywords = [], isPillar, readingTime, relatedSlugs = [] } = Astro.props;
const clusterInfo = CLUSTERS[cluster as keyof typeof CLUSTERS];

// Fetch related posts
const allPosts = await getCollection('blog');
const relatedPosts = relatedSlugs.length > 0
	? allPosts.filter(p => relatedSlugs.includes(p.id)).slice(0, 5)
	: allPosts.filter(p => p.data.cluster === cluster && p.data.title !== title).slice(0, 4);

// Article structured data
const articleSchema = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: title,
	description: description,
	datePublished: pubDate.toISOString(),
	dateModified: updatedDate ? updatedDate.toISOString() : pubDate.toISOString(),
	author: {
		'@type': 'Organization',
		name: BRAND.name,
		url: BRAND.siteUrl,
	},
	publisher: {
		'@type': 'Organization',
		name: BRAND.name,
	},
	mainEntityOfPage: {
		'@type': 'WebPage',
		'@id': Astro.url.href,
	},
	keywords: keywords.join(', '),
});
---

<html lang="vi">
	<head>
		<BaseHead title={`${title} | ${BRAND.name}`} description={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&family=Inter:wght@400;500;600&family=Playfair+Display:wght@500;600;700;800&display=swap"
			rel="stylesheet"
		/>
		<script type="application/ld+json" set:html={articleSchema} />
		<style>
			/* ── Article Layout ── */
			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding: 56px 0 0;
			}

			.hero-image {
				width: 100%;
				max-width: 780px;
				margin: 0 auto 2rem;
				padding: 0 1rem;
			}
			.hero-image img {
				display: block;
				width: 100%;
				margin: 0 auto;
				border-radius: 14px;
				box-shadow: 0 4px 20px rgba(11, 61, 107, 0.1);
				aspect-ratio: 2 / 1;
				object-fit: cover;
			}

			/* ── Prose Container ── */
			.prose {
				width: 100%;
				max-width: 680px;
				margin: 0 auto;
				padding: 0 1.25rem 3rem;
				color: var(--blog-text);
				font-family: 'Inter', 'Be Vietnam Pro', sans-serif;
				line-height: 1.75;
				font-size: 1rem;
			}

			/* ── Article Header ── */
			.article-header {
				margin-bottom: 2rem;
				padding-bottom: 0;
			}
			.article-header h1 {
				margin: 0.5em 0 0.4em;
				font-family: 'Playfair Display', 'Be Vietnam Pro', serif;
				font-size: clamp(1.6rem, 4vw, 2.25rem);
				line-height: 1.25;
				color: var(--blog-primary);
				letter-spacing: -0.02em;
				font-weight: 700;
			}

			/* ── Article Meta ── */
			.article-meta {
				display: flex;
				gap: 0.6rem;
				align-items: center;
				flex-wrap: wrap;
				margin-bottom: 0;
				color: var(--blog-text-muted);
				font-size: 0.82rem;
			}
			.cluster-badge {
				display: inline-flex;
				align-items: center;
				gap: 0.2rem;
				padding: 0.2rem 0.55rem;
				background: rgba(11, 61, 107, 0.06);
				border: 1px solid rgba(11, 61, 107, 0.1);
				border-radius: 999px;
				font-size: 0.78rem;
				font-weight: 600;
				color: var(--blog-primary);
			}
			.reading-time {
				color: var(--blog-text-light);
			}
			.last-updated-on {
				font-style: italic;
				color: var(--blog-text-light);
				font-size: 0.78rem;
			}

			/* ── Prose H2: Gold accent bar ── */
			.prose h2 {
				font-family: 'Playfair Display', 'Be Vietnam Pro', serif;
				font-size: 1.4rem;
				margin-top: 2.5em;
				margin-bottom: 0.6em;
				color: var(--blog-primary);
				border-bottom: none;
				padding-bottom: 0;
				padding-left: 0.75em;
				border-left: 3px solid var(--blog-accent);
				line-height: 1.3;
			}
			.prose h3 {
				font-family: 'Playfair Display', 'Be Vietnam Pro', serif;
				font-size: 1.15rem;
				margin-top: 2em;
				margin-bottom: 0.4em;
				color: var(--blog-primary-dark);
				font-weight: 600;
			}
			.prose h4 {
				font-size: 1rem;
				margin-top: 1.5em;
				color: var(--blog-text);
				font-weight: 600;
			}

			/* ── Prose Elements ── */
			.prose ul, .prose ol {
				padding-left: 1.25em;
				margin-bottom: 1.5em;
			}
			.prose li {
				margin-bottom: 0.35em;
				line-height: 1.7;
			}
			.prose li::marker {
				color: var(--blog-accent);
			}
			.prose strong {
				color: var(--blog-text);
				font-weight: 600;
			}
			.prose a {
				color: var(--blog-primary);
				text-decoration: underline;
				text-decoration-color: rgba(11, 61, 107, 0.2);
				text-underline-offset: 3px;
				transition: text-decoration-color 0.2s ease;
			}
			.prose a:hover {
				text-decoration-color: var(--blog-primary-light);
				color: var(--blog-primary-light);
			}

			/* ── Blockquote ── */
			.prose blockquote {
				border-left: 3px solid var(--blog-accent);
				padding: 0.75em 1.25em;
				margin: 1.5em 0;
				background: #FAFCFF;
				border-radius: 0 10px 10px 0;
				font-style: italic;
				color: var(--blog-text-muted);
			}
			.prose blockquote p:last-child {
				margin-bottom: 0;
			}

			/* ── Table ── */
			.prose table {
				width: 100%;
				max-width: 100%;
				border-collapse: collapse;
				margin: 1.5em 0;
				font-size: 0.92rem;
				border-radius: 10px;
				overflow: hidden;
				display: block;
				overflow-x: auto;
				-webkit-overflow-scrolling: touch;
			}
			.prose th, .prose td {
				border: 1px solid var(--blog-border-light);
				padding: 0.6rem 0.85rem;
				text-align: left;
			}
			.prose th {
				background: rgba(11, 61, 107, 0.04);
				font-weight: 600;
				color: var(--blog-primary);
				font-size: 0.85rem;
			}
			.prose tr:nth-child(even) td {
				background: rgba(240, 244, 248, 0.5);
			}

			/* ── Images in prose ── */
			.prose img {
				border-radius: 12px;
				box-shadow: 0 2px 12px rgba(11, 61, 107, 0.08);
				margin: 1.5em 0;
			}

			/* ── Pillar badge ── */
			.pillar-badge {
				display: inline-flex;
				align-items: center;
				gap: 0.2rem;
				padding: 0.15rem 0.6rem;
				background: linear-gradient(135deg, var(--blog-accent), var(--blog-accent-dark));
				border-radius: 999px;
				font-size: 0.72rem;
				font-weight: 700;
				color: white;
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}

			/* ── Related Posts ── */
			.related-posts {
				margin-top: 3rem;
				padding-top: 2rem;
				border-top: 1px solid var(--blog-border-light);
			}
			.related-posts h2 {
				font-family: 'Playfair Display', 'Be Vietnam Pro', serif;
				font-size: 1.2rem;
				margin: 0 0 1rem;
				border: none;
				border-left: none;
				padding-left: 0;
				color: var(--blog-primary);
			}
			.related-grid {
				display: grid;
				gap: 0.6rem;
			}
			.related-card {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				padding: 0.75rem 1rem;
				border: 1px solid var(--blog-border-light);
				border-radius: 10px;
				text-decoration: none;
				transition: all 0.18s ease;
				cursor: pointer;
			}
			.related-card:hover {
				border-color: var(--blog-primary-light);
				background: rgba(11, 61, 107, 0.03);
				transform: translateX(4px);
			}
			.related-cluster { font-size: 1.1rem; flex-shrink: 0; }
			.related-title {
				color: var(--blog-text);
				font-weight: 500;
				font-size: 0.88rem;
				line-height: 1.4;
			}

			/* ── Responsive ── */
			@media (max-width: 640px) {
				.prose {
					padding: 0 1rem 2rem;
					font-size: 0.95rem;
				}
				.article-header h1 {
					font-size: 1.5rem;
				}
				.hero-image {
					margin-bottom: 1.5rem;
					padding: 0 0.75rem;
				}
				.hero-image img {
					border-radius: 10px;
				}
				.article-meta {
					gap: 0.4rem;
				}
				.related-card {
					padding: 0.6rem 0.75rem;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt={title} />}
				</div>
				<div class="prose">
					<Breadcrumbs cluster={cluster} title={title} />
					<div class="article-header">
						<div class="article-meta">
							{clusterInfo && (
								<span class="cluster-badge">{clusterInfo.icon} {clusterInfo.name}</span>
							)}
							{isPillar && <span class="pillar-badge">⭐ Bài trụ cột</span>}
							<FormattedDate date={pubDate} />
							{readingTime && <span class="reading-time">⏱ {readingTime} phút đọc</span>}
							{updatedDate && (
								<span class="last-updated-on">
									Cập nhật: <FormattedDate date={updatedDate} />
								</span>
							)}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
					<ArticleCTA />
					{relatedPosts.length > 0 && (
						<div class="related-posts">
							<h2>📚 Bài viết liên quan</h2>
							<div class="related-grid">
								{relatedPosts.map(rp => (
									<a href={`${import.meta.env.BASE_URL}/${rp.id}/`} class="related-card">
										<span class="related-cluster">{CLUSTERS[rp.data.cluster as keyof typeof CLUSTERS]?.icon}</span>
										<span class="related-title">{rp.data.title}</span>
									</a>
								))}
							</div>
						</div>
					)}
				</div>
			</article>
		</main>
		<Footer />
		<SearchOverlay />
	</body>
</html>
