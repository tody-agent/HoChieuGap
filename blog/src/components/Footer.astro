---
import { BRAND, CLUSTERS } from '../consts';
const year = new Date().getFullYear();
const clusterEntries = Object.entries(CLUSTERS);

const orgSchema = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'Organization',
	name: BRAND.name,
	url: BRAND.siteUrl,
	contactPoint: { '@type': 'ContactPoint', telephone: BRAND.hotline, contactType: 'customer service', availableLanguage: 'Vietnamese' },
});
---

<footer class="site-footer">
	<script type="application/ld+json" set:html={orgSchema} />
	<div class="footer-grid">
		<div class="footer-brand">
			<h3>🛂 {BRAND.name}</h3>
			<p>Dịch vụ hộ chiếu gấp uy tín — Nhanh · Đúng hẹn · Hoàn tiền nếu trễ</p>
			<div class="footer-contact">
				<a href={`tel:${BRAND.hotline.replace(/\s/g, '')}`}>📞 {BRAND.hotline}</a>
				<a href={BRAND.zaloLink} target="_blank" rel="noopener">💬 Zalo</a>
				<a href={`mailto:${BRAND.email}`}>📧 {BRAND.email}</a>
			</div>
		</div>
		<div class="footer-clusters">
			<h4>Chuyên mục</h4>
			<ul>
				{clusterEntries.slice(0,5).map(([key, c]) => (
					<li><a href={`${import.meta.env.BASE_URL}?cluster=${key}`}>{c.icon} {c.name}</a></li>
				))}
			</ul>
		</div>
		<div class="footer-clusters">
			<h4>&nbsp;</h4>
			<ul>
				{clusterEntries.slice(5).map(([key, c]) => (
					<li><a href={`${import.meta.env.BASE_URL}?cluster=${key}`}>{c.icon} {c.name}</a></li>
				))}
			</ul>
		</div>
	</div>
	<div class="footer-bottom">
		<p>&copy; {year} {BRAND.name}. All rights reserved.</p>
	</div>
</footer>

<style>
	.site-footer {
		background: #1a1a2e;
		color: #d1d5db;
		padding: 3rem 1rem 1.5rem;
		font-size: 0.9rem;
	}
	.footer-grid {
		display: grid;
		grid-template-columns: 2fr 1fr 1fr;
		gap: 2rem;
		max-width: 1100px;
		margin: 0 auto;
	}
	.footer-brand h3 {
		color: white;
		margin: 0 0 0.5rem;
		font-size: 1.2rem;
	}
	.footer-brand p { margin: 0 0 1rem; opacity: 0.8; line-height: 1.5; }
	.footer-contact {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}
	.footer-contact a {
		color: #93c5fd;
		text-decoration: none;
		font-weight: 500;
	}
	.footer-contact a:hover { color: white; }
	.footer-clusters h4 {
		color: white;
		margin: 0 0 0.75rem;
		font-size: 0.95rem;
	}
	.footer-clusters ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.footer-clusters li { margin-bottom: 0.4rem; }
	.footer-clusters a {
		color: #d1d5db;
		text-decoration: none;
		font-size: 0.85rem;
		transition: color 0.15s;
	}
	.footer-clusters a:hover { color: white; }
	.footer-bottom {
		text-align: center;
		margin-top: 2rem;
		padding-top: 1.5rem;
		border-top: 1px solid rgba(255,255,255,0.1);
		opacity: 0.6;
		font-size: 0.8rem;
	}
	@media (max-width: 768px) {
		.footer-grid {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}
	}
</style>
